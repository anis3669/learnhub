modules = ["php-8.2", "nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
DB_CONNECTION = "sqlite"
SESSION_DRIVER = "file"
QUEUE_CONNECTION = "sync"
CACHE_STORE = "file"
APP_NAME = "LearnHub"
APP_ENV = "local"
APP_DEBUG = "true"
APP_URL = "http://localhost:5000"
LOG_LEVEL = "debug"
MAIL_MAILER = "log"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
