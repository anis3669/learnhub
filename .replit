modules = ["php-8.2", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_NAME = "LearnHub"
APP_ENV = "local"
APP_DEBUG = "true"
DB_CONNECTION = "pgsql"
SESSION_DRIVER = "database"
QUEUE_CONNECTION = "database"
CACHE_STORE = "database"
LOG_CHANNEL = "stack"
LOG_STACK = "single"
LOG_LEVEL = "debug"
BROADCAST_CONNECTION = "log"
FILESYSTEM_DISK = "local"
MAIL_MAILER = "log"
BCRYPT_ROUNDS = "12"
APP_KEY = "base64:E8RGt/D6z3LfGECmNkDk0Gn8m3dcX3xI02eZVec+XpQ="

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "start.sh"]
build = ["bash", "-c", "composer install --no-interaction --prefer-dist && npm install && npm run build"]
